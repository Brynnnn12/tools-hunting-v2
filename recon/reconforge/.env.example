# ReconForge — API Keys
# Copy this file to .env and fill in your keys

# Shodan — https://account.shodan.io
SHODAN_KEY=

# SecurityTrails — https://securitytrails.com/app/user/api
SECURITYTRAILS_KEY=

# AlienVault OTX — https://otx.alienvault.com (free tier, optional)
ALIENVAULT_KEY=

# LeakIX — https://leakix.net (no key needed for basic access)
LEAKIX_KEY=

# URLScan.io — https://urlscan.io (free tier, optional)
URLSCAN_KEY=
